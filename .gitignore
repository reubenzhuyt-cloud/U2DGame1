# Unity .gitignore
Assets/TextMesh Pro/Resources/Fonts & Materials/*.asset
Assets/TextMesh Pro/Resources/LineBreaking Following Characters.txt
Assets/TextMesh Pro/Resources/LineBreaking Leading Characters.txt
Assets/TextMesh Pro/Fonts/*.asset
Assets/TextMesh Pro/Sprites/*.asset
*.fontsettings
*.sdf.asset
*.sdf.png
*.sdf.asset.meta
*.sdf.png.meta
Assets/TextMesh Pro/Shaders/*.meta  # 保留shader文件，只忽略meta

# 或者更简洁的写法
Assets/TextMesh Pro/Resources/Fonts & Materials/
Assets/TextMesh Pro/Fonts/
Assets/TextMesh Pro/Sprites/

# Unity动态生成的字体纹理
Library/TextMeshPro/
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures
[Mm]emoryCaptures/

# Asset meta files
**/*.asset.meta

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.vs/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.csproj
*.unityproj
*.gameproj
*.booproj
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb
*.wut.meta*

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.dmg
*.xcodeproj

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
[Pp]ackedAddressables/

# Temporary auto-generated Android Assets
Assets/Plugins/Android/assets.meta